# Rubin Scout Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://rubinscout:rubinscout@localhost:5432/rubinscout
DATABASE_URL_SYNC=postgresql://rubinscout:rubinscout@localhost:5432/rubinscout
POSTGRES_USER=rubinscout
POSTGRES_PASSWORD=rubinscout
POSTGRES_DB=rubinscout

# ALeRCE
ALERCE_API_URL=https://api.alerce.online
# Kafka credentials (register at alerce.science for stream access)
ALERCE_KAFKA_BOOTSTRAP=kafka.alerce.science:9092
ALERCE_KAFKA_USERNAME=
ALERCE_KAFKA_PASSWORD=
ALERCE_KAFKA_GROUP_ID=rubin-scout-consumer

# Pitt-Google (optional, requires GCP project)
PITTGOOGLE_PROJECT_ID=ardent-cycling-243415
GOOGLE_APPLICATION_CREDENTIALS=

# Notifications (optional)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_FROM_EMAIL=alerts@rubinscout.dev

# App
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# Ingestion
INGESTION_INTERVAL_SECONDS=900
INGESTION_LOOKBACK_DAYS=1
MIN_CLASSIFICATION_PROBABILITY=0.5
