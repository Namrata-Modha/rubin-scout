# Rubin Scout Environment Configuration
# Copy this to .env and fill in your values

# Database (single URL, auto-converted for async/sync)
DATABASE_URL=postgresql://rubinscout:rubinscout@localhost:5432/rubinscout
POSTGRES_USER=rubinscout
POSTGRES_PASSWORD=rubinscout
POSTGRES_DB=rubinscout

# ALeRCE (enrichment: light curves and ML classifications)
ALERCE_API_URL=https://api.alerce.online
# Kafka credentials (register at alerce.science for stream access)
ALERCE_KAFKA_BOOTSTRAP=kafka.alerce.science:9092
ALERCE_KAFKA_USERNAME=
ALERCE_KAFKA_PASSWORD=
ALERCE_KAFKA_GROUP_ID=rubin-scout-consumer

# TNS (primary discovery feed: IAU Transient Name Server)
# Register a bot at https://www.wis-tns.org/user/register
# CSV-based ingestion (seeding, scheduled pulls) works without a key.
# API-based search requires the key below.
TNS_API_KEY=
TNS_BOT_ID=0
TNS_BOT_NAME=<your bot name, e.g. rubin_scout_bot>

TNS_USER_ID=<your TNS user ID from the TNS website>
TNS_USER_NAME=<your TNS username>
TNS_API_KEY=<bot API key, if you created one>

# Pitt-Google (optional, requires GCP project)
PITTGOOGLE_PROJECT_ID=ardent-cycling-243415

# Notifications (optional)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_FROM_EMAIL=alerts@rubinscout.dev

# App
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# Security
# Admin API key for write endpoints (seed, subscriptions create/update/delete).
# Not needed in development. Required in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# Ingestion
INGESTION_INTERVAL_SECONDS=900
INGESTION_LOOKBACK_DAYS=1
MIN_CLASSIFICATION_PROBABILITY=0.5
